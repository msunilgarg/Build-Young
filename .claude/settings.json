{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git cat-file:*)",
      "Bash(git rev-list:*)",
      "Bash(git ls-files:*)",
      "Bash(git merge-base:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(git commit:*)",
      "Bash(git push * claude/*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npm run test:*)",
      "Bash(npm ci:*)",
      "Bash(npm install:*)",
      "Bash(npx vitest:*)"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git push * main)",
      "Bash(git push * main *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 180,
            "statusMessage": "Syncing Build Young workspace…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/uxxxx-guard.sh"
          }
        ]
      }
    ]
  }
}
